# ─── Free mode built-in LLM (server-side, optional) ──────────
# When set, Free mode (no user API key) is powered by this LLM via the
# server-side /api/chat proxy, so the key is never exposed to the browser
# or committed to the repo. If unset, Free mode falls back to the local
# scripted responses (lib/free-coach.ts).
#
# Local dev: copy this file to `.env.local` and fill in real values.
# Production: set these in Vercel → Settings → Environment Variables.

# OpenAI-compatible provider id (e.g. zhipu, openai, deepseek, openai-compatible).
FREE_LLM_PROVIDER=zhipu
# Base URL of the provider's OpenAI-compatible endpoint.
FREE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Model name to use for Free mode conversations.
FREE_LLM_MODEL=glm-4.5-air
# The API key (KEEP SECRET — never commit the real value).
FREE_LLM_API_KEY=your-key-here
